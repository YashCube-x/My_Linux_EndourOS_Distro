{
    "label" : "shutdown",
    "action" : "systemctl poweroff",
    "text" : "Shut down",
    "keybind" : "s"
}
{
    "label" : "reboot",
    "action" : "systemctl reboot",
    "text" : "Restart",
    "keybind" : "r"
}
{
    "label" : "suspend",
    "action" : "systemctl suspend",
    "text" : "Sleep",
    "keybind" : "u"
}
{
    "label" : "logout",
    "action" : "hyprctl dispatch exit",
    "text" : "Log out",
    "keybind" : "e"
}
